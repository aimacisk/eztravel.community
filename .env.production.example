# eztravel.community — Production environment variables example
# Copy to .env.production and fill in real values (DO NOT COMMIT real values).
# In production these are injected via GCP Cloud Run --set-env-vars and --set-secrets.

CLOUD_SQL_CONNECTION_NAME=eztravel-community-prod:asia-east1:eztcomm-db
DB_PASSWORD=__REPLACE_FROM_SECRET_MANAGER__
ASPNETCORE_ENVIRONMENT=Production
