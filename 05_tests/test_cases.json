      {
        "id": "TC-04",
        "title": "已登入使用者可送出留言",
        "priority": "P0",
        "ac_ref": "AC-5",
        "note": "BUG-005 修正：登入路由為 /Identity/Account/Login；送出路由為 /api/products/{productId}/reviews",
        "prerequisites": [
          "測試帳號已在 Identity DB 建立",
          "PostgreSQL 已啟動（Production）或 InMemory DB 已 seed（Development）"
        ],
        "steps": [
          {
            "action": "POST",
            "url": "http://localhost:5150/Identity/Account/Login",
            "body": { "Input.Email": "test@test.com", "Input.Password": "Test@12345" },
            "expected_status": 302,
            "note": "取得 .AspNetCore.Identity.Application cookie"
          },
          {
            "action": "POST",
            "url": "http://localhost:5150/api/products/1/reviews",
            "headers": { "Content-Type": "application/json" },
            "body": { "rating": 4, "body": "這次旅遊體驗非常棒，導遊專業，行程安排完善。" },
            "expected_status": 201,
            "note": "需帶 auth cookie"
          }
        ],
        "assertions": [
          "response body 包含 id 欄位（新建 review id）",
          "HTTP 狀態碼為 201 Created"
        ]
      },
      {
        "id": "TC-05",
        "title": "評論列表 API 可查詢",
        "priority": "P1",
        "ac_ref": "AC-5",
        "note": "BUG-005 修正：原 TC 指定的 /review/stats 端點不存在；改測 GET /api/products/{productId}/reviews（已實作）",
        "steps": [
          {
            "action": "GET",
            "url": "http://localhost:5150/api/products/1/reviews",
            "expected_status": 200,
            "note": "公開端點，不需登入"
          }
        ],
        "assertions": [
          "response body 包含 items 陣列",
