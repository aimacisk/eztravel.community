@using EzTravel.Community.Web.Models.ViewModels
@model ProductDetailViewModel

<section class="variant variant--group-tour">
    <h2>團體行程詳情</h2>
    <ul class="variant__meta">
        <li><strong>天數:</strong> 5 天 4 夜</li>
        <li><strong>出發日:</strong> 每週二、六</li>
        <li><strong>行程性質:</strong> 含領隊 / 含三餐 / 含小費</li>
    </ul>
    <h3>逐日行程</h3>
    <ol class="variant__itinerary">
        <li>Day 1 桃園機場 → 目的地 → 飯店</li>
        <li>Day 2 市區觀光</li>
        <li>Day 3 自由活動</li>
        <li>Day 4 名勝景點</li>
        <li>Day 5 返國</li>
    </ol>
</section>
