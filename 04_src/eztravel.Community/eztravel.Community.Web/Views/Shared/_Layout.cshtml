@{
    var categories = new[]
    {
        new { Slug = "flight",    Name = "機票" },
        new { Slug = "hotel",     Name = "旅館" },
        new { Slug = "grouptour", Name = "團體" },
        new { Slug = "freetour",  Name = "自由行" },
        new { Slug = "ticket",    Name = "票券" },
        new { Slug = "spot",      Name = "景點" },
    };
}
<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - eztravel.community</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&family=Noto+Sans+TC:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/eztravel.Community.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-md navbar-dark">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">eztravel.community</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-expanded="false" aria-label="切換導覽列">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse">
                    <ul class="navbar-nav flex-grow-1">
                        @foreach (var c in categories)
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="/category/@c.Slug">@c.Name</a>
                            </li>
                        }
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer">
        <div class="container footer__inner">
            <div class="footer__grid">

                <!-- 欄一：品牌介紹 -->
                <div>
                    <div class="footer__brand-name">eztravel.community</div>
                    <p class="footer__tagline">旅遊社群平台，探索機票、旅館、團體旅遊、自由行、票券、景點，與旅人分享最美的旅程。</p>
                </div>

                <!-- 欄二：旅遊服務 -->
                <div>
                    <div class="footer__col-title">旅遊服務</div>
                    <ul class="footer__links">
                        @foreach (var c in categories)
                        {
                            <li><a href="/category/@c.Slug">@c.Name</a></li>
                        }
                    </ul>
                </div>

                <!-- 欄三：公司資訊 -->
                <div>
                    <div class="footer__col-title">公司資訊</div>
                    <ul class="footer__links">
                        <li><a asp-controller="Home" asp-action="Privacy">隱私權政策</a></li>
                        <li><a href="#">服務條款</a></li>
                        <li><a href="#">關於我們</a></li>
                        <li><a href="#">聯絡我們</a></li>
                    </ul>
                </div>

                <!-- 欄四：追蹤我們 -->
                <div>
                    <div class="footer__col-title">追蹤我們</div>
                    <ul class="footer__links">
                        <li><a href="#">Facebook</a></li>
                        <li><a href="#">Instagram</a></li>
                        <li><a href="#">LINE</a></li>
                        <li><a href="#">YouTube</a></li>
                    </ul>
                </div>
            </div>

            <div class="footer__bottom">
                <div class="footer__copyright">
                    &copy; 2026 eztravel.community &mdash; <a asp-controller="Home" asp-action="Privacy">隱私權政策</a>
                </div>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
