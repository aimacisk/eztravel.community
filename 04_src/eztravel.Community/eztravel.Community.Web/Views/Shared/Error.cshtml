@model ErrorViewModel
@{
    ViewData["Title"] = ViewData["StatusCode"] is int code ? $"錯誤 {code}" : "錯誤";
    var statusCode = ViewData["StatusCode"] as int? ?? 0;
}

<div class="error-page" style="padding: 4rem 1rem; text-align: center; max-width: 640px; margin: 0 auto;">
    @if (statusCode == 404)
    {
        <h1 style="font-size: 6rem; margin: 0; color: var(--color-brand-primary);">404</h1>
        <h2 style="margin: 1rem 0; color: var(--color-text-primary);">找不到頁面</h2>
        <p style="color: var(--color-text-secondary); margin-bottom: 2rem;">您嘗試訪問的網址不存在,可能已被移除或輸入錯誤。</p>
    }
    else if (statusCode == 500)
    {
        <h1 style="font-size: 6rem; margin: 0; color: var(--color-status-error);">500</h1>
        <h2 style="margin: 1rem 0; color: var(--color-text-primary);">伺服器錯誤</h2>
        <p style="color: var(--color-text-secondary); margin-bottom: 2rem;">很抱歉,系統處理您的請求時發生問題,我們已記錄此事件。</p>
    }
    else
    {
        <h1 style="font-size: 4rem; margin: 0; color: var(--color-status-error);">@(statusCode > 0 ? statusCode.ToString() : "錯誤")</h1>
        <h2 style="margin: 1rem 0; color: var(--color-text-primary);">處理請求時發生錯誤</h2>
        <p style="color: var(--color-text-secondary); margin-bottom: 2rem;">系統暫時無法回應您的請求,請稍後再試。</p>
    }

    <a href="/" class="btn btn-primary" style="background: var(--color-brand-primary); border-color: var(--color-brand-primary); padding: 0.75rem 2rem; font-size: 1rem;">返回首頁</a>

    @if (Model?.ShowRequestId == true)
    {
        <p style="margin-top: 2rem; font-size: 0.85rem; color: var(--color-text-muted);">
            Request ID: <code>@Model.RequestId</code>
        </p>
    }
</div>
