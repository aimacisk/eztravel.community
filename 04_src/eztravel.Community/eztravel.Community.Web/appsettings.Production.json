{
  "ConnectionStrings": {
    "DefaultConnection": "Host=/cloudsql/${CLOUD_SQL_CONNECTION_NAME};Database=eztravel;Username=postgres;Password=${DB_PASSWORD};SSL Mode=Disable;Pooling=true;Maximum Pool Size=20"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
